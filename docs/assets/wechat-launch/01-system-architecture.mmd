flowchart LR
    User["用户"] --> Frontend["Vue 中文工作台"]
    Frontend --> Backend["Spring Boot API"]
    Backend --> Metadata["平台元数据库 MySQL"]
    Backend --> Scheduler["Quartz 调度器"]
    Backend --> Generator["模拟数据生成引擎"]
    Backend --> Execution["执行记录与校验"]
    Generator --> Writer["目标端写入器"]
    Writer --> MySQL["MySQL"]
    Writer --> PostgreSQL["PostgreSQL"]
    Writer --> SQLServer["SQL Server"]
    Writer --> Oracle["Oracle"]
    Writer --> Kafka["Kafka 或 Redpanda"]
